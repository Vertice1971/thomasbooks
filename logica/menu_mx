<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Lógica para Bachillerato</title>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600&family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300&display=swap" rel="stylesheet">

<style>
  *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }

  body {
    font-family: 'Cormorant Garamond', Georgia, serif;
    min-height: 100vh;
    background: #0d0d10;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #e8e2d9;
  }

  #cover {
    position: fixed;
    inset: 0;
    background: #0d0d10;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 9999;
    transition: opacity 0.9s ease;
  }

  #cover img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  #main {
    display: none;
    width: 100vw;
    min-height: 100vh;
    padding: 56px 48px 48px;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    animation: fadeIn 0.9s ease forwards;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .header {
    text-align: center;
    margin-bottom: 48px;
  }

  .eyebrow {
    font-size: 11px;
    letter-spacing: 0.38em;
    text-transform: uppercase;
    color: #c9a84c;
    font-weight: 300;
    margin-bottom: 12px;
  }

  h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 600;
    color: #f0ebe2;
    letter-spacing: 0.02em;
    line-height: 1.15;
    margin-bottom: 16px;
  }

  .rule {
    width: 48px;
    height: 1px;
    background: #c9a84c;
    opacity: 0.65;
    margin: 0 auto;
  }

  .menu {
    display: grid;
    grid-template-columns: repeat(3, minmax(220px, 1fr));
    gap: 18px;
    width: 100%;
    max-width: 980px;
  }

  .card {
    background: #13121a;
    border: 0.5px solid #2a2733;
    border-radius: 3px;
    padding: 28px 26px 24px;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 7px;
    position: relative;
    overflow: hidden;
    transition: background 0.22s, border-color 0.22s, transform 0.2s;
  }

  .card::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 2px;
    background: #c9a84c;
    opacity: 0;
    transition: opacity 0.22s;
  }

  .card:hover {
    background: #1a1824;
    border-color: #3d3849;
    transform: translateY(-3px);
  }

  .card:hover::before {
    opacity: 1;
  }

  .num {
    font-size: 10px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: #c9a84c;
    font-weight: 300;
  }

  .label {
    font-family: 'Playfair Display', serif;
    font-size: 19px;
    font-weight: 600;
    color: #ede7dd;
  }

  .info {
    font-size: 13.5px;
    color: #4e4860;
    font-style: italic;
    font-weight: 300;
    margin-top: 2px;
  }

  .footer {
    margin-top: 36px;
    font-size: 11px;
    letter-spacing: 0.22em;
    color: #302c3a;
    text-transform: uppercase;
    font-weight: 300;
    text-align: center;
  }

  @media (max-width: 620px) {
    #main {
      padding: 40px 24px 36px;
    }

    .menu {
      grid-template-columns: 1fr;
    }
  }
</style>
</head>

<body>

<div id="cover">
  <img src="Portada.jpg" alt="Portada del libro">
</div>

<div class="container" id="main">

  <div class="header">
    <div class="eyebrow">Filosofía · Bachillerato</div>
    <h1>Lógica para Bachillerato</h1>
    <div class="rule"></div>
  </div>

  <div class="menu">

    <!-- FILA 1 -->
    <a href="https://www.amazon.es/dp/B0GXXSMN2M" class="card" target="_blank" rel="noopener noreferrer">
      <span class="label">El manual</span>
    </a>

    <a href="https://docs.google.com/document/d/1Q3EYprtg0U9N-yv9AXq3_UC1WhS4KYoz/edit?usp=drive_link&ouid=106766923080460035209&rtpof=true&sd=true" class="card" target="_blank" rel="noopener noreferrer">
      <span class="label">Programación Didáctica</span>
    </a>

    <a href="https://drive.google.com/file/d/1BmcZMleElMjmna-WW8ErJeu1knhmZu5K/view?usp=sharing" class="card" target="_blank" rel="noopener noreferrer">
      <span class="label">Solucionario de las reglas de inferencia</span>
    </a>

    <!-- FILA 2 -->
    <a href="https://vertice1971.github.io/Filosofia-Bachillerato/Tablas%20de%20verdad.html" class="card">
      <span class="label">Tablas de verdad</span>
    </a>

    <a href="https://vertice1971.github.io/Filosofia-Bachillerato/silogismos.html" class="card">
      <span class="label">Silogismos</span>
    </a>

    <a href="#" class="card">
      <span class="num">Unidad 05</span>
      <span class="label">Unidad 5</span>
      <span class="info">En proceso</span>
    </a>

    <!-- FILA 3 -->
    <a href="#" class="card">
      <span class="num">Unidad 06</span>
      <span class="label">Unidad 6</span>
      <span class="info">En proceso</span>
    </a>

    <a href="#" class="card">
      <span class="num">Unidad 07</span>
      <span class="label">Unidad 7</span>
      <span class="info">En proceso</span>
    </a>

    <a href="#" class="card">
      <span class="num">Unidad 08</span>
      <span class="label">Unidad 8</span>
      <span class="info">En proceso</span>
    </a>

  </div>

  <div class="footer">Selecciona una unidad para comenzar</div>

</div>

<script>
  window.addEventListener("load", function () {
    setTimeout(function () {
      var cover = document.getElementById("cover");
      var main  = document.getElementById("main");
      cover.style.opacity = "0";
      cover.style.transition = "opacity 0.9s ease";
      setTimeout(function () {
        cover.style.display = "none";
        main.style.display = "flex";
      }, 900);
    }, 4000);
  });
</script>

</body>
</html>
